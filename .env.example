DISCORD_TOKEN=
DISCORD_GUILD_ID=
COMMAND_PREFIX=cat!
# Docker 用 /app/sqlite-data/game.db；本地 Windows 用 sqlite-data/game.db
DB_PATH=/app/sqlite-data/game.db
# 本地 Web 服务端口，不填则默认 8080
WEB_PORT=8080
PUBLIC_EVENT_CHANNEL_ID=

# ===== Auto update (git pull) =====
# 是否自动更新（启动时检测 + 定时检查）
# 为空/0=关闭；1=true开启
AUTO_UPDATE=0
# 更新间隔（分钟）
UPDATE_INTERVAL_MINUTES=60
# 更新通道：stable=取最新 Release tag(v*) 的提交；alpha=取最新提交（origin/HEAD）
UPDATE_CHANNEL=stable